# PostgreSQL
POSTGRES_DB=ai_workflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me

# Application database connection (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:change_me@localhost:5432/ai_workflow

# Ollama (OpenAI-compatible local LLM)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=120
