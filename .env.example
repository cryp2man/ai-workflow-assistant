# PostgreSQL
POSTGRES_DB=ai_workflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me

# Application database connection (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:change_me@localhost:5432/ai_workflow

# LLM provider: "openai_compatible" (free cloud API) or "ollama" (local fallback)
LLM_PROVIDER=openai_compatible

# Free OpenAI-compatible cloud API. Pick one option below.
#
# Option 1 — Groq (default, key: https://console.groq.com/keys)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
#
# Option 2 — Google AI Studio (key: https://aistudio.google.com/apikey)
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.5-flash
#
# Option 3 — GitHub Models (token: https://github.com/settings/tokens)
# LLM_BASE_URL=https://models.github.ai/inference
# LLM_MODEL=openai/gpt-4o-mini
#
LLM_API_KEY=change_me
LLM_TIMEOUT=120

# Ollama (OpenAI-compatible local LLM, offline fallback)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=120
